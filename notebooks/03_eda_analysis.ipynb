# Cell 1: Call and display your generated plots inside the workspace
from IPython.display import Image, display
import os

charts_dir = "reports/charts"
for chart_file in sorted(os.listdir(charts_dir)):
    if chart_file.endswith(".png"):
        print(f"📊 Displaying Evaluation Chart: {chart_file}")
        display(Image(filename=os.path.join(charts_dir, chart_file)))